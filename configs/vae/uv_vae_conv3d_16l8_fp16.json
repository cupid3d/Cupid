{
    "models": {
        "encoder": {
            "name": "SparseStructureEncoder",
            "args": {
                "in_channels": 3,
                "latent_channels": 8,
                "num_res_blocks": 2,
                "num_res_blocks_middle": 2,
                "channels": [32, 128, 512],
                "use_fp16": true
            }
        },
        "decoder": {
            "name": "SparseStructureDecoder",
            "args": {
                "out_channels": 3,
                "latent_channels": 8,
                "num_res_blocks": 2,
                "num_res_blocks_middle": 2,
                "channels": [512, 128, 32],
                "use_fp16": true
            }
        }
    },
    "dataset": {
        "name": "ImageConditionedSparseUVStructure",
        "args": {
            "resolution": 64,
            "min_aesthetic_score": 4.5,
            "discard_occluded_voxels": false,
            "dilation_sigma": 0.0,
            "dilation_min_weight": 0.05,
            "crop_size_ratio": [1.0, 1.4, 1.5],
            "crop_prob": 1.0,
            "crop_in_eval": true,
            "const_ssuv": true
        }
    },
    "trainer": {
        "name": "SparseUVStructureVaeTrainer",
        "args": {
            "max_steps": 1000000,
            "batch_size_per_gpu": 4,
            "batch_split": 1,
            "finetune_ckpt": {
                "encoder": "checkpoint/TRELLIS-image-large/ckpts/ss_enc_conv3d_16l8_fp16.safetensors",
                "decoder": "checkpoint/TRELLIS-image-large/ckpts/ss_dec_conv3d_16l8_fp16.safetensors"
            },
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 1e-4,
                    "weight_decay": 0.0
                }
            },
            "ema_rate": [
                0.9999
            ],
            "fp16_mode": "inflat_all",
            "fp16_scale_growth": 0.001,
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 1.0,
                    "clip_percentile": 95
                }
            },
            "i_log": 500,
            "i_sample": 10000,
            "i_save": 10000,
            "classification_loss_type": "dice",
            "regression_loss_type": "l1",
            "uv_loss_mask": "ssuv",
            "input_ssuv": true,
            "input_uv_volume": true,
            "predict_ssuv": true,
            "lambda_kl": 0.001,
            "lambda_uv_volume": 1.0
        }
    },
    "evaluator": {
        "name": "SparseUVStructureVaeEvaluator",
        "args": {
            "batch_size_per_gpu": 8,
            "input_ssuv": true,
            "input_uv_volume": true,
            "predict_ssuv": true,
            "use_ss_as_weights": true,
            "dilation_sigma": 0.5,
            "dilation_min_weight": 0.05
        }
    }
}